generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum OrgRole {
  ADMIN
  AP_CLERK
  FINANCE_MANAGER
  CONTROLLER
  CFO
  VENDOR
  CLIENT
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  avatar       String?
  passwordHash String
  orgId        String?
  role         OrgRole?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  memberships  OrgMember[]

  @@map("users")
}

model Organisation {
  id        String      @id @default(cuid())
  name      String
  slug      String      @unique
  plan      String      @default("starter")
  settings  Json        @default("{}")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  members               OrgMember[]
  entityRelationships   EntityOrgRelationship[]
  serviceEngagements    ServiceEngagement[]
  processingRules       ProcessingRule[]
  approvalWorkflows     ApprovalWorkflow[]
  purchaseOrders        PurchaseOrder[]
  documents             Document[]
  contracts             Contract[]
  onboardingWorkflows   OnboardingWorkflow[]
  onboardingInstances   OnboardingInstance[]
  thirdPartyReviews     ThirdPartyReview[]
  reviewCadences        ReviewCadence[]
  entityActivityLogs    EntityActivityLog[]
  recurringSchedules    RecurringSchedule[]
  invoices              Invoice[]

  @@map("organisations")
}

model OrgMember {
  id        String       @id @default(cuid())
  orgId     String
  userId    String
  role      OrgRole
  status    String       @default("active")
  createdAt DateTime     @default(now())

  org       Organisation @relation(fields: [orgId], references: [id])
  user      User         @relation(fields: [userId], references: [id])

  @@unique([orgId, userId])
  @@map("org_members")
}

// ============================================================
// Entity Master — Phase 2
// ============================================================

enum LegalStructure {
  INDIVIDUAL
  COMPANY
  FUND
  TRUST
  GOVERNMENT
  OTHER
}

enum EntityType {
  VENDOR
  CONTRACTOR
  PARTNER
  COUNTERPARTY
  SERVICE_PROVIDER
  BROKER
  PLATFORM
  FUND_SERVICE
  OTHER
}

enum EntityStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_REVIEW
  OFFBOARDED
}

enum OnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum KycStatus {
  NOT_REQUIRED
  PENDING
  IN_REVIEW
  APPROVED
  FAILED
  EXPIRED
}

enum KybStatus {
  NOT_REQUIRED
  PENDING
  IN_REVIEW
  APPROVED
  FAILED
  EXPIRED
}

enum SanctionsStatus {
  CLEAR
  FLAGGED
  UNDER_REVIEW
  BLOCKED
}

enum PaymentRail {
  ACH
  BACS
  SWIFT
  SEPA
  WIRE
  STRIPE
  ERP
  OTHER
}

enum SlaStatus {
  ON_TRACK
  AT_RISK
  BREACHED
  NOT_APPLICABLE
}

enum ServiceCategory {
  BANKING
  CUSTODY
  FUND_ADMIN
  OUTSOURCING
  LEGAL
  AUDIT
  TECHNOLOGY
  COMPLIANCE
  OTHER
}

model Entity {
  id                 String        @id @default(cuid())
  masterOrgId        String
  name               String
  slug               String        @unique
  legalStructure     LegalStructure
  registrationNo     String?
  jurisdiction       String?
  incorporationDate  DateTime?
  status             EntityStatus  @default(ACTIVE)
  primaryCurrency    String        @default("USD")
  riskScore          Float         @default(0)
  riskOverride       Boolean       @default(false)
  parentId           String?
  ultimateParentId   String?
  metadata           Json          @default("{}")
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  parent             Entity?                  @relation("EntityParent",        fields: [parentId],         references: [id])
  children           Entity[]                 @relation("EntityParent")
  ultimateParent     Entity?                  @relation("EntityUltimateParent", fields: [ultimateParentId], references: [id])
  ultimateChildren   Entity[]                 @relation("EntityUltimateParent")

  classifications           EntityClassification[]
  bankAccounts              EntityBankAccount[]
  dueDiligence              EntityDueDiligence?
  financial                 EntityFinancial?
  riskScores                EntityRiskScore[]
  orgRelationships          EntityOrgRelationship[]
  serviceEngagements        ServiceEngagement[]
  processingRuleEvaluations ProcessingRuleEvaluation[]
  purchaseOrders            PurchaseOrder[]
  onboardingInstances       OnboardingInstance[]
  thirdPartyReviews         ThirdPartyReview[]
  entityActivityLogs        EntityActivityLog[]
  recurringSchedules        RecurringSchedule[]
  invoices                  Invoice[]
  externalSignalConfigs     ExternalSignalConfig[]
  externalSignals           ExternalSignal[]

  @@map("entities")
}

model EntityClassification {
  id        String      @id @default(cuid())
  entityId  String
  type      EntityType
  isPrimary Boolean     @default(false)
  startDate DateTime?
  endDate   DateTime?
  notes     String?
  createdAt DateTime    @default(now())

  entity    Entity      @relation(fields: [entityId], references: [id])

  @@unique([entityId, type])
  @@map("entity_classifications")
}

model EntityBankAccount {
  id          String        @id @default(cuid())
  entityId    String
  label       String
  isPrimary   Boolean       @default(false)
  accountName String
  accountNo   String
  routingNo   String?
  swiftBic    String?
  iban        String?
  currency    String        @default("USD")
  paymentRail PaymentRail
  status      EntityStatus  @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  entity      Entity        @relation(fields: [entityId], references: [id])

  @@map("entity_bank_accounts")
}

model EntityDueDiligence {
  id              String          @id @default(cuid())
  entityId        String          @unique
  ddLevel         Int             @default(1)
  kycStatus       KycStatus       @default(NOT_REQUIRED)
  kybStatus       KybStatus       @default(NOT_REQUIRED)
  sanctionsStatus SanctionsStatus @default(CLEAR)
  pepStatus       Boolean         @default(false)
  reviewedAt      DateTime?
  reviewedBy      String?
  nextReviewDate  DateTime?
  internalFactors Json            @default("{}")
  externalFactors Json            @default("{}")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  entity          Entity          @relation(fields: [entityId], references: [id])

  @@map("entity_due_diligence")
}

model EntityFinancial {
  id                   String    @id @default(cuid())
  entityId             String    @unique
  paymentTerms         Int       @default(30)
  defaultCurrency      String    @default("USD")
  taxId                String?
  vatNumber            String?
  glCode               String?
  costCentre           String?
  creditLimit          Float?
  preferredBankAccountId String?
  invoiceCount         Int       @default(0)
  spendYTD             Float     @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  entity               Entity    @relation(fields: [entityId], references: [id])

  @@map("entity_financials")
}

model EntityRiskScore {
  id                   String    @id @default(cuid())
  entityId             String
  computedScore        Float
  parentInfluence      Float     @default(0)
  ddScore              Float     @default(0)
  behaviorScore        Float     @default(0)
  sanctionsScore       Float     @default(0)
  paymentHistoryScore  Float     @default(0)
  weights              Json
  notes                String?
  scoredAt             DateTime  @default(now())
  scoredBy             String?

  entity               Entity    @relation(fields: [entityId], references: [id])

  @@map("entity_risk_scores")
}

model EntityOrgRelationship {
  id                      String           @id @default(cuid())
  entityId                String
  orgId                   String
  managedBy               String?
  onboardingStatus        OnboardingStatus @default(NOT_STARTED)
  onboardingCompletedAt   DateTime?
  contractStart           DateTime?
  contractEnd             DateTime?
  approvedSpendLimit      Float?
  portalAccess            Boolean          @default(false)
  portalUserId            String?
  activeForBillPay        Boolean          @default(false)
  notes                   String?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  entity                  Entity           @relation(fields: [entityId], references: [id])
  org                     Organisation     @relation(fields: [orgId], references: [id])

  @@unique([entityId, orgId])
  @@map("entity_org_relationships")
}

model ServiceCatalogue {
  id          String            @id @default(cuid())
  name        String            @unique
  category    ServiceCategory
  description String?
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  engagements ServiceEngagement[]

  @@map("service_catalogue")
}

model ServiceEngagement {
  id                   String           @id @default(cuid())
  entityId             String
  serviceCatalogueId   String
  orgId                String
  internalOwner        String?
  department           String?
  status               EntityStatus     @default(ACTIVE)
  contractId           String?
  contractStart        DateTime?
  contractEnd          DateTime?
  slaTarget            String?
  slaStatus            SlaStatus        @default(NOT_APPLICABLE)
  lastReviewedAt       DateTime?
  complianceDocs       Json             @default("[]")
  notes                String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  entity               Entity           @relation(fields: [entityId], references: [id])
  serviceCatalogue     ServiceCatalogue @relation(fields: [serviceCatalogueId], references: [id])
  org                  Organisation     @relation(fields: [orgId], references: [id])

  @@unique([entityId, serviceCatalogueId, orgId])
  @@map("service_engagements")
}

// ============================================================
// Procurement & Document Management — Phase 3
// ============================================================

enum PoType {
  FIXED
  OPEN
  BLANKET
}

enum PoStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  INVOICED
  CLOSED
  CANCELLED
}

enum ProcessingTrack {
  FULL_PO
  LIGHTWEIGHT
  STP
  CONTRACT_REQUIRED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  DELEGATED
  CANCELLED
}

enum GoodsReceiptStatus {
  PARTIAL
  FULL
  REJECTED
}

enum DocumentSource {
  INTERNAL
  VENDOR
  SYSTEM
}

enum DocType {
  QUOTE
  PROPOSAL
  CONTRACT
  SOW
  INVOICE
  RECEIPT
  APPROVAL
  COMPLIANCE
  CERTIFICATE
  REPORT
  AMENDMENT
  OTHER
}

enum ESignStatus {
  NOT_REQUIRED
  PENDING
  SENT
  SIGNED
  DECLINED
  EXPIRED
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
  UNDER_REVIEW
  RENEWED
}

enum ContractType {
  MASTER
  SOW
  AMENDMENT
  NDA
  SLA
  FRAMEWORK
  OTHER
}

model ProcessingRule {
  id                   String          @id @default(cuid())
  orgId                String
  name                 String
  description          String?
  priority             Int
  isActive             Boolean         @default(true)
  conditions           Json
  track                ProcessingTrack
  requiresGoodsReceipt Boolean         @default(false)
  requiresContract     Boolean         @default(false)
  notes                String?
  createdBy            String
  updatedBy            String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  org                  Organisation              @relation(fields: [orgId], references: [id])
  evaluations          ProcessingRuleEvaluation[]
  purchaseOrders       PurchaseOrder[]

  @@index([orgId, priority])
  @@map("processing_rules")
}

model ProcessingRuleEvaluation {
  id                 String           @id @default(cuid())
  orgId              String
  ruleId             String?
  entityId           String
  amount             Float
  currency           String
  conditionsSnapshot Json
  matched            Boolean
  trackAssigned      ProcessingTrack?
  evaluatedAt        DateTime         @default(now())
  evaluatedBy        String?
  sourceType         String
  sourceId           String

  rule               ProcessingRule?  @relation(fields: [ruleId], references: [id])
  entity             Entity           @relation(fields: [entityId], references: [id])

  @@index([sourceType, sourceId])
  @@index([orgId, evaluatedAt])
  @@map("processing_rule_evaluations")
}

model ApprovalWorkflow {
  id              String        @id @default(cuid())
  orgId           String
  name            String
  description     String?
  spendCategories String[]
  departments     String[]
  thresholdMin    Float         @default(0)
  thresholdMax    Float?
  steps           Json
  isActive        Boolean       @default(true)
  createdBy       String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  org             Organisation   @relation(fields: [orgId], references: [id])
  purchaseOrders  PurchaseOrder[]
  poApprovals     POApproval[]

  @@map("approval_workflows")
}

model PurchaseOrder {
  id                     String           @id @default(cuid())
  orgId                  String
  poNumber               String
  title                  String
  description            String?
  type                   PoType
  track                  ProcessingTrack
  status                 PoStatus         @default(DRAFT)
  entityId               String
  serviceEngagementId    String?
  processingRuleId       String?
  processingRuleSnapshot Json?
  approvalWorkflowId     String?
  totalAmount            Float
  currency               String           @default("USD")
  amountSpent            Float            @default(0)
  spendCategory          String?
  department             String?
  costCentre             String?
  glCode                 String?
  requestedBy            String
  validFrom              DateTime?
  validTo                DateTime?
  requiresGoodsReceipt   Boolean          @default(false)
  requiresContract       Boolean          @default(false)
  currentVersion         Int              @default(1)
  notes                  String?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  org              Organisation      @relation(fields: [orgId], references: [id])
  entity           Entity            @relation(fields: [entityId], references: [id])
  processingRule   ProcessingRule?   @relation(fields: [processingRuleId], references: [id])
  approvalWorkflow ApprovalWorkflow? @relation(fields: [approvalWorkflowId], references: [id])
  lineItems        POLineItem[]
  approvals        POApproval[]
  amendments       POAmendment[]
  goodsReceipts    GoodsReceipt[]
  documents        Document[]

  @@unique([orgId, poNumber])
  @@map("purchase_orders")
}

model POLineItem {
  id          String        @id @default(cuid())
  poId        String
  lineNo      Int
  description String
  quantity    Float         @default(1)
  unitPrice   Float
  totalPrice  Float
  currency    String        @default("USD")
  glCode      String?
  costCentre  String?
  taxRate     Float         @default(0)
  notes       String?

  po          PurchaseOrder @relation(fields: [poId], references: [id])

  @@unique([poId, lineNo])
  @@map("po_line_items")
}

model POApproval {
  id          String           @id @default(cuid())
  poId        String
  workflowId  String?
  step        Int
  approverId  String
  status      ApprovalStatus   @default(PENDING)
  decidedAt   DateTime?
  comments    String?
  delegatedTo String?
  notifiedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  po          PurchaseOrder     @relation(fields: [poId], references: [id])
  workflow    ApprovalWorkflow? @relation(fields: [workflowId], references: [id])

  @@map("po_approvals")
}

model POAmendment {
  id             String        @id @default(cuid())
  poId           String
  version        Int
  changedFields  Json
  previousValues Json
  newValues      Json
  reason         String
  amendedBy      String
  amendedAt      DateTime      @default(now())

  po             PurchaseOrder @relation(fields: [poId], references: [id])

  @@unique([poId, version])
  @@map("po_amendments")
}

model GoodsReceipt {
  id         String             @id @default(cuid())
  poId       String
  orgId      String
  receivedAt DateTime
  receivedBy String
  status     GoodsReceiptStatus
  lineItems  Json
  notes      String?
  createdAt  DateTime           @default(now())

  po         PurchaseOrder @relation(fields: [poId], references: [id])

  @@map("goods_receipts")
}

model Document {
  id                  String         @id @default(cuid())
  orgId               String
  title               String
  docType             DocType
  source              DocumentSource @default(INTERNAL)
  storageRef          String
  storageBucket       String
  mimeType            String?
  fileSizeBytes       Int?
  entityId            String?
  poId                String?
  contractId          String?
  serviceEngagementId String?
  status              String         @default("active")
  expiresAt           DateTime?
  issuedAt            DateTime?
  issuedBy            String?
  eSignRequired       Boolean        @default(false)
  eSignStatus         ESignStatus    @default(NOT_REQUIRED)
  eSignProvider       String?
  eSignEnvelopeId     String?
  eSignCompletedAt    DateTime?
  uploadedBy          String
  metadata            Json           @default("{}")
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  org                 Organisation   @relation(fields: [orgId], references: [id])
  po                  PurchaseOrder? @relation(fields: [poId], references: [id])

  @@index([orgId, docType])
  @@index([entityId])
  @@index([poId])
  @@map("documents")
}

model Contract {
  id               String         @id @default(cuid())
  orgId            String
  documentId       String         @unique
  entityId         String
  contractNo       String
  type             ContractType
  status           ContractStatus @default(DRAFT)
  value            Float?
  currency         String         @default("USD")
  startDate        DateTime?
  endDate          DateTime?
  renewalDate      DateTime?
  autoRenew        Boolean        @default(false)
  noticePeriodDays Int            @default(30)
  ownedBy          String
  reviewedAt       DateTime?
  linkedPoId       String?
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  org              Organisation   @relation(fields: [orgId], references: [id])

  @@unique([orgId, contractNo])
  @@index([orgId, status])
  @@index([endDate])
  @@map("contracts")
}

// ============================================================
// Onboarding, Reviews, Invoicing & Signals — Phase 4
// ============================================================

enum OnboardingStepType {
  DOCUMENT
  REVIEW
  APPROVAL
  EXTERNAL_CHECK
  INFORMATION
}

enum OnboardingInstanceStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  PENDING_APPROVAL
  COMPLETED
  REJECTED
}

enum ReviewType {
  ONBOARDING
  PERIODIC
  EVENT_TRIGGERED
}

enum ReviewStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  OVERDUE
  CANCELLED
}

enum ReviewDomain {
  CYBERSECURITY
  LEGAL
  PRIVACY
  FINANCIAL
  OPERATIONAL
}

enum ActivityType {
  ONBOARDING
  REVIEW
  PAYMENT
  STATUS_CHANGE
  INCIDENT
  DOCUMENT
  NOTE
  EXTERNAL_SIGNAL
  RISK_SCORE_CHANGE
}

enum InvoiceStatus {
  RECEIVED
  MATCHED
  UNMATCHED
  PENDING_REVIEW
  APPROVED
  REJECTED
  PAID
  CANCELLED
  DUPLICATE
}

enum InvoiceSource {
  EMAIL
  PORTAL
  MANUAL
  EDI
}

enum MatchType {
  TWO_WAY
  THREE_WAY
  NONE
}

enum InvoiceDecisionType {
  AUTO_APPROVE
  REVIEW
  ESCALATE
  REJECT
}

enum PaymentStatus {
  SCHEDULED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  RECONCILED
}

enum PaymentRailExecution {
  ERP
  BANK_API
  STRIPE
}

enum SignalType {
  NEWS
  STOCK_PRICE
}

enum SignalSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model OnboardingWorkflow {
  id          String      @id @default(cuid())
  orgId       String
  name        String
  description String?
  entityTypes EntityType[]
  steps       Json
  isActive    Boolean     @default(true)
  createdBy   String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  org         Organisation        @relation(fields: [orgId], references: [id])
  instances   OnboardingInstance[]

  @@map("onboarding_workflows")
}

model OnboardingInstance {
  id              String                   @id @default(cuid())
  entityId        String
  orgId           String
  workflowId      String
  status          OnboardingInstanceStatus @default(NOT_STARTED)
  currentStep     Int                      @default(1)
  completedSteps  Json                     @default("[]")
  startedAt       DateTime?
  completedAt     DateTime?
  blockedReason   String?
  assignedTo      String?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  entity          Entity             @relation(fields: [entityId], references: [id])
  org             Organisation       @relation(fields: [orgId], references: [id])
  workflow        OnboardingWorkflow @relation(fields: [workflowId], references: [id])

  @@unique([entityId, orgId, workflowId])
  @@map("onboarding_instances")
}

model ThirdPartyReview {
  id              String       @id @default(cuid())
  entityId        String
  orgId           String
  reviewType      ReviewType
  status          ReviewStatus @default(IN_PROGRESS)
  cyberScore      Float?
  legalScore      Float?
  privacyScore    Float?
  overallScore    Float?
  cyberFindings   Json         @default("{}")
  legalFindings   Json         @default("{}")
  privacyFindings Json         @default("{}")
  reviewedBy      String?
  approvedBy      String?
  scheduledAt     DateTime?
  completedAt     DateTime?
  nextReviewDate  DateTime?
  triggerEvent    String?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  entity          Entity       @relation(fields: [entityId], references: [id])
  org             Organisation @relation(fields: [orgId], references: [id])

  @@index([entityId, reviewType])
  @@index([nextReviewDate])
  @@map("third_party_reviews")
}

model ReviewCadence {
  id                  String         @id @default(cuid())
  orgId               String
  name                String
  riskScoreMin        Float          @default(0)
  riskScoreMax        Float          @default(10)
  reviewIntervalDays  Int
  domains             ReviewDomain[]
  isActive            Boolean        @default(true)
  createdBy           String
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  org                 Organisation   @relation(fields: [orgId], references: [id])

  @@map("review_cadences")
}

model EntityActivityLog {
  id             String       @id @default(cuid())
  entityId       String
  orgId          String
  activityType   ActivityType
  title          String
  description    String?
  referenceId    String?
  referenceType  String?
  performedBy    String?
  occurredAt     DateTime     @default(now())
  metadata       Json         @default("{}")

  entity         Entity       @relation(fields: [entityId], references: [id])
  org            Organisation @relation(fields: [orgId], references: [id])

  @@index([entityId, occurredAt])
  @@index([orgId, activityType])
  @@map("entity_activity_logs")
}

model RecurringSchedule {
  id                  String       @id @default(cuid())
  orgId               String
  entityId            String
  name                String
  description         String?
  spendCategory       String?
  expectedAmount      Float
  currency            String       @default("USD")
  frequency           String
  dayOfMonth          Int?
  toleranceFixed      Float        @default(0)
  tolerancePct        Float        @default(0.02)
  toleranceDynamic    Float        @default(1.0)
  isActive            Boolean      @default(true)
  lastInvoiceAt       DateTime?
  lastInvoiceAmount   Float?
  invoiceCount        Int          @default(0)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  org                 Organisation @relation(fields: [orgId], references: [id])
  entity              Entity       @relation(fields: [entityId], references: [id])

  @@map("recurring_schedules")
}

model Invoice {
  id                  String        @id @default(cuid())
  orgId               String
  invoiceNo           String
  entityId            String
  poId                String?
  recurringScheduleId String?
  amount              Float
  currency            String        @default("USD")
  invoiceDate         DateTime
  dueDate             DateTime?
  status              InvoiceStatus @default(RECEIVED)
  source              InvoiceSource
  isRecurring         Boolean       @default(false)
  matchType           MatchType     @default(NONE)
  documentId          String?
  rawExtraction       Json          @default("{}")
  notes               String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  org                 Organisation       @relation(fields: [orgId], references: [id])
  entity              Entity             @relation(fields: [entityId], references: [id])
  riskEvaluations     RiskEvaluation[]
  decision            InvoiceDecision?
  paymentExecutions   PaymentExecution[]

  @@unique([orgId, invoiceNo])
  @@index([entityId, status])
  @@index([dueDate])
  @@map("invoices")
}

model RiskEvaluation {
  id                 String   @id @default(cuid())
  invoiceId          String
  orgId              String
  overallScore       Float
  amountScore        Float    @default(0)
  frequencyScore     Float    @default(0)
  vendorScore        Float    @default(0)
  duplicateScore     Float    @default(0)
  toleranceScore     Float    @default(0)
  weights            Json
  flags              Json     @default("[]")
  explanation        Json
  withinTolerance    Boolean  @default(true)
  deviation          Float    @default(0)
  deviationPct       Float    @default(0)
  effectiveTolerance Float    @default(0)
  evaluatedAt        DateTime @default(now())

  invoice            Invoice  @relation(fields: [invoiceId], references: [id])

  @@map("risk_evaluations")
}

model InvoiceDecision {
  id               String              @id @default(cuid())
  invoiceId        String              @unique
  decision         InvoiceDecisionType
  riskScore        Float
  reasoning        Json
  decidedAt        DateTime            @default(now())
  decidedBy        String
  overriddenBy     String?
  overriddenAt     DateTime?
  overrideReason   String?
  previousDecision InvoiceDecisionType?

  invoice          Invoice @relation(fields: [invoiceId], references: [id])

  @@map("invoice_decisions")
}

model PaymentExecution {
  id            String               @id @default(cuid())
  invoiceId     String
  orgId         String
  entityId      String?
  amount        Float
  currency      String               @default("USD")
  rail          PaymentRailExecution
  status        PaymentStatus        @default(SCHEDULED)
  scheduledAt   DateTime?
  executedAt    DateTime?
  reference     String?
  bankAccountId String?
  reconciled    Boolean              @default(false)
  reconciledAt  DateTime?
  glPosted      Boolean              @default(false)
  glPostedAt    DateTime?
  failureReason String?
  retryCount    Int                  @default(0)
  metadata      Json                 @default("{}")
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  invoice       Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@index([status, scheduledAt])
  @@map("payment_executions")
}

model ExternalSignalConfig {
  id                 String          @id @default(cuid())
  entityId           String
  orgId              String
  signalTypes        SignalType[]
  stockTicker        String?
  companyName        String
  newsKeywords       String[]
  severityThreshold  SignalSeverity  @default(MEDIUM)
  alertRecipients    String[]
  isActive           Boolean         @default(true)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  entity             Entity @relation(fields: [entityId], references: [id])

  @@unique([entityId, orgId])
  @@map("external_signal_configs")
}

model ExternalSignal {
  id               String        @id @default(cuid())
  entityId         String
  orgId            String
  signalType       SignalType
  severity         SignalSeverity
  title            String
  summary          String
  sourceUrl        String?
  sourceName       String?
  rawData          Json          @default("{}")
  publishedAt      DateTime?
  detectedAt       DateTime      @default(now())
  reviewedBy       String?
  reviewedAt       DateTime?
  dismissed        Boolean       @default(false)
  affectedRiskScore Boolean      @default(false)

  entity           Entity @relation(fields: [entityId], references: [id])

  @@index([entityId, detectedAt])
  @@index([severity, dismissed])
  @@map("external_signals")
}

// ============================================================
// AuditEvent is append-only — no updates or deletes should ever be issued against this table.
model AuditEvent {
  id         String   @id @default(cuid())
  orgId      String
  actorId    String?
  action     String
  entityType String
  entityId   String?
  before     Json?
  after      Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@map("audit_events")
}
