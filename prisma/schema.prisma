generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum OrgRole {
  ADMIN
  AP_CLERK
  FINANCE_MANAGER
  CONTROLLER
  CFO
  VENDOR
  CLIENT
  AUDITOR
  LEGAL
  CISO
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String?
  avatar            String?
  passwordHash      String
  orgId             String?
  role              OrgRole?
  emailVerified     Boolean   @default(false)
  emailVerifyToken  String?   @unique
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  memberships             OrgMember[]
  notificationPreference  NotificationPreference?
  invoiceApprovals        InvoiceApproval[]       @relation("InvoiceAssignee")

  @@map("users")
}

model InviteToken {
  id        String    @id @default(cuid())
  token     String    @unique @default(cuid())
  email     String?
  usedAt    DateTime?
  expiresAt DateTime
  createdBy String
  orgId     String
  createdAt DateTime  @default(now())

  @@map("invite_tokens")
}

model Organisation {
  id        String      @id @default(cuid())
  name      String
  slug      String      @unique
  plan      String      @default("starter")
  settings  Json        @default("{}")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  members                  OrgMember[]
  entityRelationships      EntityOrgRelationship[]
  serviceEngagements       ServiceEngagement[]
  purchaseOrders           PurchaseOrder[]
  documents                Document[]
  contracts                Contract[]
  thirdPartyReviews        ThirdPartyReview[]
  reviewCadences           ReviewCadence[]
  entityActivityLogs       EntityActivityLog[]
  recurringSchedules       RecurringSchedule[]
  invoices                 Invoice[]
  paymentInstructions      PaymentInstruction[]
  invoiceIngestionEvents   InvoiceIngestionEvent[]
  invoiceApprovals         InvoiceApproval[]
  mergedAuthorizations     MergedAuthorization[]
  notificationPreferences  NotificationPreference[]

  @@map("organisations")
}

model OrgMember {
  id        String       @id @default(cuid())
  orgId     String
  userId    String
  role      OrgRole
  status    String       @default("active")
  createdAt DateTime     @default(now())

  org       Organisation @relation(fields: [orgId], references: [id])
  user      User         @relation(fields: [userId], references: [id])

  @@unique([orgId, userId])
  @@map("org_members")
}

// ============================================================
// Entity Master — Phase 2
// ============================================================

enum LegalStructure {
  INDIVIDUAL
  COMPANY
  FUND
  TRUST
  GOVERNMENT
  OTHER
}

enum EntityType {
  VENDOR
  CONTRACTOR
  BROKER
  PLATFORM
  FUND_SVC_PROVIDER
  OTHER
}

enum WorkflowType {
  ENTITY
  INVOICE
  PURCHASE_ORDER
  OTHER
}

enum EntityStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_REVIEW
  OFFBOARDED
  PROVISIONAL
}

enum OnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum KycStatus {
  NOT_REQUIRED
  PENDING
  IN_REVIEW
  APPROVED
  FAILED
  EXPIRED
}

enum KybStatus {
  NOT_REQUIRED
  PENDING
  IN_REVIEW
  APPROVED
  FAILED
  EXPIRED
}

enum SanctionsStatus {
  CLEAR
  FLAGGED
  UNDER_REVIEW
  BLOCKED
}

enum PaymentRail {
  ACH
  BACS
  SWIFT
  SEPA
  WIRE
  STRIPE
  ERP
  OTHER
}

enum SlaStatus {
  ON_TRACK
  AT_RISK
  BREACHED
  NOT_APPLICABLE
}



model Entity {
  id                 String        @id @default(cuid())
  masterOrgId        String
  name               String
  slug               String        @unique
  legalStructure     LegalStructure
  registrationNo     String?
  jurisdiction       String?
  incorporationDate  DateTime?
  status             EntityStatus  @default(ACTIVE)
  primaryCurrency    String        @default("USD")
  riskScore          Float         @default(0)
  riskOverride       Boolean       @default(false)
  riskBand           RiskBand?
  riskBandUpdatedAt  DateTime?
  riskBandOverride   RiskBand?
  riskBandOverrideReason String?
  riskBandOverrideBy String?
  riskBandOverrideAt DateTime?
  parentId           String?
  stockTicker        String?
  metadata           Json          @default("{}")
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  parent             Entity?                  @relation("EntityParent", fields: [parentId], references: [id])
  children           Entity[]                 @relation("EntityParent")

  classifications           EntityClassification[]
  bankAccounts              EntityBankAccount[]
  dueDiligence              EntityDueDiligence?
  financial                 EntityFinancial?
  riskScores                EntityRiskScore[]
  orgRelationships          EntityOrgRelationship[]
  serviceEngagements        ServiceEngagement[]
  processingRuleEvaluations ProcessingRuleEvaluation[]
  purchaseOrders            PurchaseOrder[]
  thirdPartyReviews         ThirdPartyReview[]
  entityActivityLogs        EntityActivityLog[]
  recurringSchedules        RecurringSchedule[]
  invoices                  Invoice[]
  externalSignalConfigs     ExternalSignalConfig[]
  externalSignals           ExternalSignal[]
  vendorSpendSnapshots      VendorSpendSnapshot[]

  @@map("entities")
}

model EntityClassification {
  id        String      @id @default(cuid())
  entityId  String
  type      EntityType
  isPrimary Boolean     @default(false)
  startDate DateTime?
  endDate   DateTime?
  notes     String?
  createdAt DateTime    @default(now())

  entity    Entity      @relation(fields: [entityId], references: [id])

  @@unique([entityId, type])
  @@map("entity_classifications")
}

model EntityBankAccount {
  id          String        @id @default(cuid())
  entityId    String
  label       String
  isPrimary   Boolean       @default(false)
  accountName String
  accountNo   String
  routingNo   String?
  swiftBic    String?
  iban        String?
  currency    String        @default("USD")
  paymentRail PaymentRail
  status      EntityStatus  @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  entity      Entity        @relation(fields: [entityId], references: [id])

  @@map("entity_bank_accounts")
}

model EntityDueDiligence {
  id              String          @id @default(cuid())
  entityId        String          @unique
  ddLevel         Int             @default(1)
  kycStatus       KycStatus       @default(NOT_REQUIRED)
  kybStatus       KybStatus       @default(NOT_REQUIRED)
  sanctionsStatus SanctionsStatus @default(CLEAR)
  pepStatus       Boolean         @default(false)
  reviewedAt      DateTime?
  reviewedBy      String?
  nextReviewDate  DateTime?
  internalFactors Json            @default("{}")
  externalFactors Json            @default("{}")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  entity          Entity          @relation(fields: [entityId], references: [id])

  @@map("entity_due_diligence")
}

model EntityFinancial {
  id                   String    @id @default(cuid())
  entityId             String    @unique
  paymentTerms         Int       @default(30)
  defaultCurrency      String    @default("USD")
  taxId                String?
  vatNumber            String?
  glCode               String?
  costCentre           String?
  creditLimit          Float?
  preferredBankAccountId String?
  invoiceCount         Int       @default(0)
  spendYTD             Float     @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  entity               Entity    @relation(fields: [entityId], references: [id])

  @@map("entity_financials")
}

model EntityRiskScore {
  id                   String    @id @default(cuid())
  entityId             String
  computedScore        Float
  parentInfluence      Float     @default(0)
  ddScore              Float     @default(0)
  behaviorScore        Float     @default(0)
  sanctionsScore       Float     @default(0)
  paymentHistoryScore  Float     @default(0)
  weights              Json
  notes                String?
  scoredAt             DateTime  @default(now())
  scoredBy             String?
  // 2A risk band fields
  score                Float?
  band                 RiskBand?
  computedAt           DateTime?
  factors              Json?

  entity               Entity    @relation(fields: [entityId], references: [id])

  @@map("entity_risk_scores")
}

model EntityOrgRelationship {
  id                      String           @id @default(cuid())
  entityId                String
  orgId                   String
  managedBy               String?
  onboardingStatus        OnboardingStatus @default(NOT_STARTED)
  onboardingCompletedAt   DateTime?
  contractStart           DateTime?
  contractEnd             DateTime?
  approvedSpendLimit      Float?
  portalAccess            Boolean          @default(false)
  portalUserId            String?
  activeForBillPay        Boolean          @default(false)
  notes                   String?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  entity                  Entity           @relation(fields: [entityId], references: [id])
  org                     Organisation     @relation(fields: [orgId], references: [id])

  @@unique([entityId, orgId])
  @@map("entity_org_relationships")
}

model ServiceCatalogue {
  id          String   @id @default(cuid())
  name        String
  parentId    String?
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent      ServiceCatalogue?  @relation("ServiceTree", fields: [parentId], references: [id])
  children    ServiceCatalogue[] @relation("ServiceTree")
  engagements ServiceEngagement[]

  @@map("service_catalogue")
}

model ServiceEngagement {
  id                   String           @id @default(cuid())
  entityId             String
  serviceCatalogueId   String
  orgId                String
  internalOwner        String?
  department           String?
  status               EntityStatus     @default(ACTIVE)
  contractId           String?
  contractStart        DateTime?
  contractEnd          DateTime?
  slaTarget            String?
  slaStatus            SlaStatus        @default(NOT_APPLICABLE)
  lastReviewedAt       DateTime?
  complianceDocs       Json             @default("[]")
  notes                String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  entity               Entity           @relation(fields: [entityId], references: [id])
  serviceCatalogue     ServiceCatalogue @relation(fields: [serviceCatalogueId], references: [id])
  org                  Organisation     @relation(fields: [orgId], references: [id])

  @@unique([entityId, serviceCatalogueId, orgId])
  @@map("service_engagements")
}

// ============================================================
// Procurement & Document Management — Phase 3
// ============================================================

enum PoType {
  FIXED
  OPEN
  BLANKET
}

enum PoStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  INVOICED
  CLOSED
  CANCELLED
}

enum ProcessingTrack {
  FULL_PO
  LIGHTWEIGHT
  STP
  CONTRACT_REQUIRED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  DELEGATED
  CANCELLED
}

enum GoodsReceiptStatus {
  PARTIAL
  FULL
  REJECTED
}

enum DocumentSource {
  INTERNAL
  VENDOR
  SYSTEM
}

enum DocType {
  QUOTE
  PROPOSAL
  CONTRACT
  SOW
  INVOICE
  RECEIPT
  APPROVAL
  COMPLIANCE
  CERTIFICATE
  REPORT
  AMENDMENT
  OTHER
}

enum ESignStatus {
  NOT_REQUIRED
  PENDING
  SENT
  SIGNED
  DECLINED
  EXPIRED
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
  UNDER_REVIEW
  RENEWED
}

enum ContractType {
  MASTER
  SOW
  AMENDMENT
  NDA
  SLA
  FRAMEWORK
  OTHER
}


model ProcessingRuleEvaluation {
  id                 String           @id @default(cuid())
  orgId              String
  ruleId             String?
  entityId           String
  amount             Float
  currency           String
  conditionsSnapshot Json
  matched            Boolean
  trackAssigned      ProcessingTrack?
  evaluatedAt        DateTime         @default(now())
  evaluatedBy        String?
  sourceType         String
  sourceId           String

  entity             Entity           @relation(fields: [entityId], references: [id])

  @@index([sourceType, sourceId])
  @@index([orgId, evaluatedAt])
  @@map("processing_rule_evaluations")
}


model PurchaseOrder {
  id                     String           @id @default(cuid())
  orgId                  String
  poNumber               String
  title                  String
  description            String?
  type                   PoType
  track                  ProcessingTrack
  status                 PoStatus         @default(DRAFT)
  entityId               String
  serviceEngagementId    String?
  processingRuleId       String?
  processingRuleSnapshot Json?
  approvalWorkflowId     String?
  totalAmount            Float
  currency               String           @default("USD")
  amountSpent            Float            @default(0)
  spendCategory          String?
  department             String?
  costCentre             String?
  glCode                 String?
  requestedBy            String
  validFrom              DateTime?
  validTo                DateTime?
  requiresGoodsReceipt   Boolean          @default(false)
  requiresContract       Boolean          @default(false)
  currentVersion         Int              @default(1)
  notes                  String?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  org              Organisation      @relation(fields: [orgId], references: [id])
  entity           Entity            @relation(fields: [entityId], references: [id])
  lineItems        POLineItem[]
  approvals        POApproval[]
  amendments       POAmendment[]
  goodsReceipts    GoodsReceipt[]
  documents        Document[]

  @@unique([orgId, poNumber])
  @@map("purchase_orders")
}

model POLineItem {
  id          String        @id @default(cuid())
  poId        String
  lineNo      Int
  description String
  quantity    Float         @default(1)
  unitPrice   Float
  totalPrice  Float
  currency    String        @default("USD")
  glCode      String?
  costCentre  String?
  taxRate     Float         @default(0)
  notes       String?

  po          PurchaseOrder @relation(fields: [poId], references: [id])

  @@unique([poId, lineNo])
  @@map("po_line_items")
}

model POApproval {
  id          String           @id @default(cuid())
  poId        String
  workflowId  String?
  step        Int
  approverId  String
  status      ApprovalStatus   @default(PENDING)
  decidedAt   DateTime?
  comments    String?
  delegatedTo String?
  notifiedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  po          PurchaseOrder     @relation(fields: [poId], references: [id])

  @@map("po_approvals")
}

model POAmendment {
  id             String        @id @default(cuid())
  poId           String
  version        Int
  changedFields  Json
  previousValues Json
  newValues      Json
  reason         String
  amendedBy      String
  amendedAt      DateTime      @default(now())

  po             PurchaseOrder @relation(fields: [poId], references: [id])

  @@unique([poId, version])
  @@map("po_amendments")
}

model GoodsReceipt {
  id         String             @id @default(cuid())
  poId       String
  orgId      String
  receivedAt DateTime
  receivedBy String
  status     GoodsReceiptStatus
  lineItems  Json
  notes      String?
  createdAt  DateTime           @default(now())

  po         PurchaseOrder @relation(fields: [poId], references: [id])

  @@map("goods_receipts")
}

model Document {
  id                  String         @id @default(cuid())
  orgId               String
  title               String
  docType             DocType
  source              DocumentSource @default(INTERNAL)
  storageRef          String
  storageBucket       String
  mimeType            String?
  fileSizeBytes       Int?
  entityId            String?
  poId                String?
  contractId          String?
  serviceEngagementId String?
  status              String         @default("active")
  expiresAt           DateTime?
  issuedAt            DateTime?
  issuedBy            String?
  eSignRequired       Boolean        @default(false)
  eSignStatus         ESignStatus    @default(NOT_REQUIRED)
  eSignProvider       String?
  eSignEnvelopeId     String?
  eSignCompletedAt    DateTime?
  uploadedBy          String
  metadata            Json           @default("{}")
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  org                 Organisation   @relation(fields: [orgId], references: [id])
  po                  PurchaseOrder? @relation(fields: [poId], references: [id])

  @@index([orgId, docType])
  @@index([entityId])
  @@index([poId])
  @@map("documents")
}

model Contract {
  id               String         @id @default(cuid())
  orgId            String
  documentId       String         @unique
  entityId         String
  contractNo       String
  type             ContractType
  status           ContractStatus @default(DRAFT)
  value            Float?
  currency         String         @default("USD")
  startDate        DateTime?
  endDate          DateTime?
  renewalDate      DateTime?
  autoRenew        Boolean        @default(false)
  noticePeriodDays Int            @default(30)
  ownedBy          String
  reviewedAt       DateTime?
  linkedPoId       String?
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  org              Organisation   @relation(fields: [orgId], references: [id])
  invoices         Invoice[]

  @@unique([orgId, contractNo])
  @@index([orgId, status])
  @@index([endDate])
  @@map("contracts")
}

// ============================================================
// Onboarding, Reviews, Invoicing & Signals — Phase 4
// ============================================================


enum ReviewType {
  ONBOARDING
  PERIODIC
  EVENT_TRIGGERED
}

enum ReviewStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  OVERDUE
  CANCELLED
}

enum ReviewDomain {
  CYBERSECURITY
  LEGAL
  PRIVACY
  FINANCIAL
  OPERATIONAL
}

enum ActivityType {
  ONBOARDING
  REVIEW
  PAYMENT
  STATUS_CHANGE
  INCIDENT
  DOCUMENT
  NOTE
  EXTERNAL_SIGNAL
  RISK_SCORE_CHANGE
}

enum InvoiceStatus {
  RECEIVED
  MATCHED
  UNMATCHED
  PENDING_REVIEW
  APPROVED
  REJECTED
  PAID
  CANCELLED
  DUPLICATE
}

enum InvoiceSource {
  EMAIL
  PORTAL
  MANUAL
  EDI
  RECURRING
}

enum MatchType {
  TWO_WAY
  THREE_WAY
  NONE
}

enum InvoiceDecisionType {
  AUTO_APPROVE
  REVIEW
  ESCALATE
  REJECT
}

enum RiskTier {
  LOW
  MEDIUM
  HIGH
}

enum RiskBand {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskSignalType {
  NEW_VENDOR
  AMOUNT_VARIANCE
  NO_CONTRACT_MATCH
  CONTRACT_EXPIRED
  CONTRACT_EXPIRING_SOON
  DUPLICATE_FLAG
  MISSING_FIELDS
  UNCONTRACTED_SPEND
  AMOUNT_OVER_THRESHOLD
  FREQUENCY_ANOMALY
  SANCTION_FLAG
}

enum DuplicateFlagStatus {
  QUARANTINED
  OVERRIDE_APPROVED
  FALSE_POSITIVE
}

enum InvoiceApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  DELEGATED
  EXPIRED
}

enum MergedAuthStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  PAID
}

enum PaymentStatus {
  SCHEDULED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  RECONCILED
}

enum PaymentRailExecution {
  ERP
  BANK_API
  STRIPE
}

enum SignalType {
  NEWS
  STOCK_PRICE
}

enum SignalSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}


enum DependencyType {
  ENTITY_CONFIRMED
  RISK_SCORE_READY
  ONBOARDING_COMPLETE
  APPROVAL_COMPLETE
}

model StepDependency {
  id             String         @id @default(cuid())
  stepId         String         // references WorkflowStepInstance.id (the waiting step instance)
  dependencyType DependencyType
  subjectId      String         // the ID of the thing being waited on (e.g. entityId)
  resolvedAt     DateTime?      // null means still waiting
  createdAt      DateTime       @default(now())

  step           WorkflowStepInstance @relation(fields: [stepId], references: [id])

  @@index([dependencyType, subjectId, resolvedAt])
  @@index([stepId])
  @@map("step_dependencies")
}

model ThirdPartyReview {
  id              String       @id @default(cuid())
  entityId        String
  orgId           String
  reviewType      ReviewType
  status          ReviewStatus @default(IN_PROGRESS)
  cyberScore      Float?
  legalScore      Float?
  privacyScore    Float?
  overallScore    Float?
  cyberFindings   Json         @default("{}")
  legalFindings   Json         @default("{}")
  privacyFindings Json         @default("{}")
  reviewedBy      String?
  approvedBy      String?
  scheduledAt     DateTime?
  completedAt     DateTime?
  nextReviewDate  DateTime?
  triggerEvent    String?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  entity          Entity       @relation(fields: [entityId], references: [id])
  org             Organisation @relation(fields: [orgId], references: [id])

  @@index([entityId, reviewType])
  @@index([nextReviewDate])
  @@map("third_party_reviews")
}

model ReviewCadence {
  id                  String         @id @default(cuid())
  orgId               String
  name                String
  riskScoreMin        Float          @default(0)
  riskScoreMax        Float          @default(10)
  reviewIntervalDays  Int
  domains             ReviewDomain[]
  isActive            Boolean        @default(true)
  createdBy           String
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  org                 Organisation   @relation(fields: [orgId], references: [id])

  @@map("review_cadences")
}

model EntityActivityLog {
  id             String       @id @default(cuid())
  entityId       String
  orgId          String
  activityType   ActivityType
  title          String
  description    String?
  referenceId    String?
  referenceType  String?
  performedBy    String?
  occurredAt     DateTime     @default(now())
  metadata       Json         @default("{}")

  entity         Entity       @relation(fields: [entityId], references: [id])
  org            Organisation @relation(fields: [orgId], references: [id])

  @@index([entityId, occurredAt])
  @@index([orgId, activityType])
  @@map("entity_activity_logs")
}

model RecurringSchedule {
  id                  String       @id @default(cuid())
  orgId               String
  entityId            String
  name                String
  description         String?
  spendCategory       String?
  expectedAmount      Float
  currency            String       @default("USD")
  frequency           String
  dayOfMonth          Int?
  toleranceFixed      Float        @default(0)
  tolerancePct        Float        @default(0.02)
  toleranceDynamic    Float        @default(1.0)
  isActive            Boolean      @default(true)
  lastInvoiceAt       DateTime?
  lastInvoiceAmount   Float?
  invoiceCount        Int          @default(0)
  nextRunAt           DateTime?    // set after each run; null = never run (eligible immediately)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  org                 Organisation @relation(fields: [orgId], references: [id])
  entity              Entity       @relation(fields: [entityId], references: [id])

  @@index([isActive, nextRunAt])
  @@map("recurring_schedules")
}

model Invoice {
  id                  String        @id @default(cuid())
  orgId               String
  invoiceNo           String
  entityId            String
  poId                String?
  contractId          String?
  contractMatchConf   Float?                         // AI confidence for contract match (0–1)
  recurringScheduleId String?
  amount              Float
  currency            String        @default("USD")
  invoiceDate         DateTime
  dueDate             DateTime?
  status              InvoiceStatus @default(RECEIVED)
  source              InvoiceSource
  isRecurring         Boolean       @default(false)
  matchType           MatchType     @default(NONE)
  documentId          String?
  emailMessageId      String?       @unique           // inbound email Message-ID header, for dedup
  pdfFingerprint      String?                        // SHA-256 of raw PDF bytes, for dedup
  rawExtraction       Json          @default("{}")
  riskBand            RiskBand?
  notes               String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  org                 Organisation          @relation(fields: [orgId], references: [id])
  entity              Entity                @relation(fields: [entityId], references: [id])
  contract            Contract?             @relation(fields: [contractId], references: [id])
  riskEvaluations     RiskEvaluation[]
  decision            InvoiceDecision?
  paymentExecutions   PaymentExecution[]
  extractedFields     InvoiceExtractedField[]
  // InvoiceApproval is the source of truth for approver state; this is a convenience back-relation
  approvals           InvoiceApproval[]
  duplicateFlags      InvoiceDuplicateFlag[] @relation("DuplicateSuspect")
  flaggedAsOriginal   InvoiceDuplicateFlag[] @relation("DuplicateOriginal")
  ingestionEvent      InvoiceIngestionEvent?
  mergedAuthItem      MergedAuthItem?

  @@unique([orgId, invoiceNo])
  @@index([entityId, status])
  @@index([contractId])
  @@index([dueDate])
  @@map("invoices")
}

model RiskEvaluation {
  id                 String    @id @default(cuid())
  invoiceId          String
  orgId              String
  overallScore       Float
  tier               RiskTier?                      // LOW / MEDIUM / HIGH derived from overallScore
  amountScore        Float     @default(0)
  frequencyScore     Float     @default(0)
  vendorScore        Float     @default(0)
  duplicateScore     Float     @default(0)
  toleranceScore     Float     @default(0)
  weights            Json
  flags              Json      @default("[]")
  explanation        Json
  withinTolerance    Boolean   @default(true)
  deviation          Float     @default(0)
  deviationPct       Float     @default(0)
  effectiveTolerance Float     @default(0)
  evaluatedAt        DateTime  @default(now())

  invoice            Invoice     @relation(fields: [invoiceId], references: [id])
  signals            RiskSignal[]

  @@map("risk_evaluations")
}

model InvoiceDecision {
  id               String              @id @default(cuid())
  invoiceId        String              @unique
  decision         InvoiceDecisionType
  riskScore        Float
  reasoning        Json
  decidedAt        DateTime            @default(now())
  decidedBy        String
  overriddenBy     String?
  overriddenAt     DateTime?
  overrideReason   String?
  previousDecision InvoiceDecisionType?

  invoice          Invoice @relation(fields: [invoiceId], references: [id])

  @@map("invoice_decisions")
}

model PaymentExecution {
  id            String               @id @default(cuid())
  invoiceId     String
  orgId         String
  entityId      String?
  amount        Float
  currency      String               @default("USD")
  rail          PaymentRailExecution
  status        PaymentStatus        @default(SCHEDULED)
  scheduledAt   DateTime?
  executedAt    DateTime?
  reference     String?
  bankAccountId String?
  reconciled    Boolean              @default(false)
  reconciledAt  DateTime?
  glPosted      Boolean              @default(false)
  glPostedAt    DateTime?
  failureReason String?
  retryCount    Int                  @default(0)
  metadata      Json                 @default("{}")
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  invoice       Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@index([status, scheduledAt])
  @@map("payment_executions")
}

model ExternalSignalConfig {
  id                 String          @id @default(cuid())
  entityId           String
  orgId              String
  signalTypes        SignalType[]
  stockTicker        String?
  companyName        String
  newsKeywords       String[]
  severityThreshold  SignalSeverity  @default(MEDIUM)
  alertRecipients    String[]
  isActive           Boolean         @default(true)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  entity             Entity @relation(fields: [entityId], references: [id])

  @@unique([entityId, orgId])
  @@map("external_signal_configs")
}

model ExternalSignal {
  id               String        @id @default(cuid())
  entityId         String
  orgId            String
  signalType       SignalType
  severity         SignalSeverity
  title            String
  summary          String
  sourceUrl        String?
  sourceName       String?
  rawData          Json          @default("{}")
  publishedAt      DateTime?
  detectedAt       DateTime      @default(now())
  reviewedBy       String?
  reviewedAt       DateTime?
  dismissed        Boolean       @default(false)
  affectedRiskScore Boolean      @default(false)

  entity           Entity @relation(fields: [entityId], references: [id])

  @@index([entityId, detectedAt])
  @@index([severity, dismissed])
  @@map("external_signals")
}

// ============================================================
// Payment Instructions, ERP Sync & Period Management — Phase 5
// ============================================================

enum PaymentInstructionStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENT_TO_ERP
  CONFIRMED
  CANCELLED
  FAILED
  AMENDMENT_PENDING
  RECONCILED
}

enum AmendmentStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ErpTransactionType {
  VENDOR_BILL
  VENDOR_PAYMENT
  JOURNAL_ENTRY
  CREDIT_MEMO
  PURCHASE_ORDER
}

enum ErpSyncStatus {
  IN_PROGRESS
  SUCCESS
  PARTIAL
  FAILED
}

enum ErpSyncTrigger {
  MANUAL
  SCHEDULED
  WEBHOOK
}

model PaymentInstruction {
  id                  String                   @id @default(cuid())
  orgId               String
  invoiceId           String                   @unique
  entityId            String
  bankAccountId       String
  amount              Float
  currency            String                   @default("USD")
  dueDate             DateTime?
  glCode              String?
  costCentre          String?
  poReference         String?
  status              PaymentInstructionStatus @default(DRAFT)
  currentVersion      Int                      @default(1)
  createdBy           String
  approvedBy          String?
  approvedAt          DateTime?
  sentToErpAt         DateTime?
  erpReference        String?
  confirmedAt         DateTime?
  confirmedAmount     Float?
  cancelledAt         DateTime?
  cancellationReason  String?
  notes               String?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  org                 Organisation                    @relation(fields: [orgId], references: [id])
  versions            PaymentInstructionVersion[]
  amendments          PaymentInstructionAmendment[]

  @@index([orgId, status])
  @@map("payment_instructions")
}

// Append-only — no updates or deletes should ever be issued against this table.
model PaymentInstructionVersion {
  id                    String   @id @default(cuid())
  paymentInstructionId  String
  version               Int
  entityId              String
  bankAccountId         String
  amount                Float
  currency              String
  dueDate               DateTime?
  glCode                String?
  costCentre            String?
  snapshotAt            DateTime @default(now())
  snapshotBy            String
  changeReason          String?

  paymentInstruction    PaymentInstruction @relation(fields: [paymentInstructionId], references: [id])

  @@unique([paymentInstructionId, version])
  @@map("payment_instruction_versions")
}

// One PENDING amendment per paymentInstructionId is enforced by the partial unique
// index in migration 20260509000004_simplify_payment_amendment:
//   CREATE UNIQUE INDEX "payment_instruction_amendments_pending_unique"
//   ON "payment_instruction_amendments" ("paymentInstructionId")
//   WHERE "status" = 'PENDING';
//
// The `changes` field stores a freeform diff object, e.g.:
//   { "amount": { "from": 100, "to": 150 }, "bankAccountId": { "from": "ba-1", "to": "ba-2" } }
model PaymentInstructionAmendment {
  id                    String          @id @default(cuid())
  paymentInstructionId  String
  changes               Json            @default("{}")
  status                AmendmentStatus @default(PENDING)
  requestedBy           String
  requestedAt           DateTime        @default(now())
  reviewedBy            String?
  reviewedAt            DateTime?
  rejectionReason       String?
  notes                 String?

  paymentInstruction    PaymentInstruction @relation(fields: [paymentInstructionId], references: [id])

  @@index([paymentInstructionId, status])
  @@map("payment_instruction_amendments")
}

model ErpTransaction {
  id                    String             @id @default(cuid())
  orgId                 String
  entityId              String
  erpInternalId         String
  erpTransactionType    ErpTransactionType
  transactionDate       DateTime
  amount                Float
  currency              String
  vendorRef             String?
  paymentReference      String?
  period                String
  periodClosed          Boolean            @default(false)
  currentVersionNo      Int                @default(1)
  lastSyncedAt          DateTime           @default(now())
  paymentInstructionId  String?

  versions              ErpTransactionVersion[]

  @@unique([orgId, erpInternalId])
  @@index([entityId])
  @@index([period, periodClosed])
  @@map("erp_transactions")
}

// Append-only — no updates or deletes should ever be issued against this table.
model ErpTransactionVersion {
  id                          String   @id @default(cuid())
  erpTransactionId            String
  versionNo                   Int
  transactionDate             DateTime
  amount                      Float
  currency                    String
  vendorRef                   String?
  paymentReference            String?
  period                      String
  periodClosed                Boolean
  previousValues              Json
  detectedAt                  DateTime @default(now())
  detectedBySync              String?
  periodWasClosedAtDetection  Boolean  @default(false)

  erpTransaction              ErpTransaction @relation(fields: [erpTransactionId], references: [id])

  @@unique([erpTransactionId, versionNo])
  @@map("erp_transaction_versions")
}

model ErpPeriod {
  id        String    @id @default(cuid())
  orgId     String
  period    String
  startDate DateTime
  endDate   DateTime
  closedAt  DateTime?
  closedBy  String?
  isOpen    Boolean   @default(true)

  @@unique([orgId, period])
  @@map("erp_periods")
}

model ErpSyncLog {
  id                   String         @id @default(cuid())
  orgId                String
  trigger              ErpSyncTrigger
  triggeredBy          String?
  status               ErpSyncStatus
  startedAt            DateTime       @default(now())
  completedAt          DateTime?
  durationMs           Int?
  transactionsChecked  Int            @default(0)
  transactionsChanged  Int            @default(0)
  thirdPartyRelevant   Int            @default(0)
  newTransactions      Int            @default(0)
  errors               Json           @default("[]")
  notes                String?

  @@map("erp_sync_logs")
}

// ============================================================
// FX rates — one row per currency pair per day, sourced from ECB via Frankfurter
model FxRate {
  id            String   @id @default(cuid())
  baseCurrency  String   @default("USD")
  quoteCurrency String
  rate          Float
  rateDate      DateTime
  source        String   @default("ECB")
  createdAt     DateTime @default(now())

  @@unique([baseCurrency, quoteCurrency, rateDate])
  @@index([quoteCurrency, rateDate])
  @@map("fx_rates")
}

// ============================================================
// Pre-computed report snapshots — one row per org/reportType/period
model ReportSnapshot {
  id           String   @id @default(cuid())
  orgId        String
  reportType   String
  period       String
  snapshotDate DateTime @default(now())
  data         Json
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now())

  @@index([orgId, reportType, period])
  @@index([orgId, snapshotDate])
  @@map("report_snapshots")
}

// ============================================================
// AuditEvent is append-only — no updates or deletes should ever be issued against this table.
model AuditEvent {
  id         String   @id @default(cuid())
  orgId      String
  actorId    String?
  action     String
  entityType String
  entityId   String?
  before     Json?
  after      Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@map("audit_events")
}

// ============================================================
// Control Framework — enums

enum ControlDomain {
  ACCESS_CONTROL
  CHANGE_MANAGEMENT
  FINANCIAL_INTEGRITY
  VENDOR_RISK
  BC_DR
  MONITORING
}

enum ControlFrequency {
  CONTINUOUS
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  PER_EVENT
}

enum ControlStatus {
  ACTIVE
  INACTIVE
  UNDER_REVIEW
  DEPRECATED
}

enum TestResultStatus {
  PASS
  FAIL
  WARNING
  NOT_RUN
  ERROR
}

enum EvidenceType {
  AUTOMATED_TEST
  MANUAL_REVIEW
  DOCUMENT
  SCREENSHOT
  EXPORT
  SIGN_OFF
}

enum AuditPeriodStatus {
  OPEN
  CLOSED
  LOCKED
}

// ============================================================
// Control — defines a control requirement within the framework
model Control {
  id               String          @id @default(cuid())
  controlId        String          @unique                  // e.g. "AC-01"
  orgId            String
  domain           ControlDomain
  title            String
  objective        String                                   // what this control achieves
  frequency        ControlFrequency
  ownerRole        String                                   // which role is responsible
  automatedTestKey String?                                  // key linking to the automated test function
  sox              Boolean         @default(false)          // relevant to SOX
  soc2Criteria     String[]                                 // e.g. ["CC6.1", "CC9.1"]
  status           ControlStatus   @default(ACTIVE)
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  testResults      ControlTestResult[]
  evidence         ControlEvidence[]

  @@index([orgId, domain])
  @@index([controlId])
  @@map("controls")
}

// ============================================================
// AuditPeriod — a defined window of time for an audit engagement
model AuditPeriod {
  id            String            @id @default(cuid())
  orgId         String
  name          String                                      // e.g. "SOC2 Type II — Q1 2026"
  framework     String                                      // e.g. "SOC2", "SOX", "INTERNAL"
  periodStart   DateTime
  periodEnd     DateTime
  status        AuditPeriodStatus @default(OPEN)
  openedBy      String                                      // userId
  closedBy      String?
  closedAt      DateTime?
  lockedBy      String?
  lockedAt      DateTime?
  auditorNotes  String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  testResults   ControlTestResult[]
  evidence      ControlEvidence[]

  @@unique([orgId, name])
  @@map("audit_periods")
}

// ============================================================
// ControlTestResult — append-only record of a control test execution.
// No updates or deletes should ever be issued against this table.
model ControlTestResult {
  id            String           @id @default(cuid())
  controlId     String
  orgId         String
  auditPeriodId String?                                     // FK hint to AuditPeriod
  status        TestResultStatus
  summary       String                                      // one-line result description
  details       Json                                        // full test output, counts, sampled records
  evidence      Json             @default("[]")             // array of { type, description, storageRef? }
  testedAt      DateTime         @default(now())
  testedBy      String                                      // userId or 'system'
  reviewedBy    String?                                     // userId who signed off
  reviewedAt    DateTime?
  reviewNotes   String?

  control       Control          @relation(fields: [controlId], references: [id])
  auditPeriod   AuditPeriod?     @relation(fields: [auditPeriodId], references: [id])

  @@index([controlId, testedAt])
  @@index([orgId, status])
  @@map("control_test_results")
}

// ============================================================
// ControlEvidence — evidence artefacts collected for a control
model ControlEvidence {
  id            String       @id @default(cuid())
  controlId     String
  orgId         String
  auditPeriodId String?                                     // FK hint to AuditPeriod
  evidenceType  EvidenceType
  title         String
  description   String?
  storageRef    String?                                     // Supabase storage path in audit-evidence bucket
  storageHash   String?                                     // SHA256 of the file for integrity verification
  collectedAt   DateTime     @default(now())
  collectedBy   String                                      // userId or 'system'
  reviewedBy    String?
  reviewedAt    DateTime?
  metadata      Json         @default("{}")

  control       Control      @relation(fields: [controlId], references: [id])
  auditPeriod   AuditPeriod? @relation(fields: [auditPeriodId], references: [id])

  @@index([controlId, collectedAt])
  @@index([auditPeriodId])
  @@map("control_evidence")
}

// ============================================================
// BcDrRecord — BC/DR test and incident records
model BcDrRecord {
  id              String           @id @default(cuid())
  orgId           String
  recordType      String                                    // BACKUP_VERIFICATION, RTO_TEST, RPO_TEST, INCIDENT, RECOVERY
  rtoTargetHours  Float            @default(8)
  rpoTargetHours  Float            @default(24)
  actualRtoHours  Float?                                    // measured during test/incident
  actualRpoHours  Float?                                    // measured during test/incident
  status          TestResultStatus
  description     String
  testedAt        DateTime         @default(now())
  testedBy        String
  evidence        Json             @default("[]")
  notes           String?

  @@index([orgId, recordType])
  @@map("bc_dr_records")
}

// ============================================================
// EntityStockPrice — daily OHLCV price history per entity/ticker
model EntityStockPrice {
  id          String   @id @default(cuid())
  entityId    String                        // FK hint to Entity
  ticker      String
  priceDate   DateTime                      // trading day (midnight UTC)
  closePrice  Float
  openPrice   Float?
  highPrice   Float?
  lowPrice    Float?
  volume      BigInt?
  changeAmt   Float?                        // close minus prior day close
  changePct   Float?                        // percentage change from prior day
  week52High  Float?
  week52Low   Float?
  currency    String   @default("USD")
  source      String   @default("yahoo_finance")
  createdAt   DateTime @default(now())

  @@unique([entityId, ticker, priceDate])
  @@index([entityId, priceDate])
  @@index([ticker, priceDate])
  @@map("entity_stock_prices")
}

// ============================================================
// Invoice Ingestion — Phase 6
// ============================================================

// Raw inbound event record. Created before the invoice is parsed so we have a
// complete audit trail of every webhook/upload attempt regardless of outcome.
model InvoiceIngestionEvent {
  id               String        @id @default(cuid())
  orgId            String
  // Linked after parsing succeeds; null if processing failed.
  invoiceId        String?       @unique
  source           InvoiceSource
  receivedAt       DateTime      @default(now())

  // Email inbound (Resend webhook)
  emailMessageId   String?       @unique
  fromEmail        String?
  fromName         String?
  subject          String?
  // [{filename, storageRef, mimeType, sizeBytes}]
  attachmentRefs   Json?

  // File upload (Supabase Storage)
  storageRef       String?
  uploadedBy       String?

  processingStatus String        @default("PENDING") // PENDING | PARSED | FAILED
  errorDetails     String?
  // Full webhook payload stored for replay/debugging. Secrets must be stripped before storage.
  rawPayload       Json?

  createdAt        DateTime      @default(now())

  org              Organisation  @relation(fields: [orgId], references: [id])
  invoice          Invoice?      @relation(fields: [invoiceId], references: [id])

  @@index([orgId, receivedAt])
  @@index([processingStatus])
  @@map("invoice_ingestion_events")
}

// Per-field AI extraction result with confidence score. Supersedes the opaque
// rawExtraction Json on Invoice for any field that needs human review routing.
model InvoiceExtractedField {
  id              String   @id @default(cuid())
  invoiceId       String
  // Canonical field names: invoiceNo | vendorName | amount | currency |
  //   invoiceDate | dueDate | poNumber | lineItems | taxAmount | subtotal
  fieldName       String
  rawValue        String?
  normalizedValue String?
  confidence      Float              // 0.0 – 1.0
  modelVersion    String?
  // True when confidence is below the org threshold; queued for human correction.
  needsReview     Boolean  @default(false)
  reviewedBy      String?
  reviewedAt      DateTime?
  reviewedValue   String?            // human-corrected value, if changed

  invoice         Invoice  @relation(fields: [invoiceId], references: [id])

  @@unique([invoiceId, fieldName])
  @@index([invoiceId])
  @@index([needsReview])
  @@map("invoice_extracted_fields")
}

// Individual scored signal contributing to a RiskEvaluation.
// Replaces opaque flags Json with queryable, weighted rows.
model RiskSignal {
  id               String         @id @default(cuid())
  riskEvaluationId String
  signalType       RiskSignalType
  triggered        Boolean
  value            Float?         // raw measurement (e.g. variance amount, days to expiry)
  weight           Float?         // contribution weight used in overallScore
  detail           String?        // human-readable explanation

  riskEvaluation   RiskEvaluation @relation(fields: [riskEvaluationId], references: [id])

  @@index([riskEvaluationId])
  @@map("risk_signals")
}

// First-class financial control for duplicate detection.
// Suspects are QUARANTINED (blocked from the queue) until reviewed.
// Any override requires a written justification that is stored here permanently.
model InvoiceDuplicateFlag {
  id                    String              @id @default(cuid())
  orgId                 String
  invoiceId             String              // the suspect invoice
  duplicateOfInvoiceId  String?             // the original, if identified

  // Signal breakdown — at least one will be true on a QUARANTINED record
  matchedOnInvoiceNo    Boolean             @default(false)
  matchedOnVendorAmount Boolean             @default(false) // same vendor + amount + date proximity
  matchedOnPdfHash      Boolean             @default(false)
  matchedOnEmailMsgId   Boolean             @default(false)
  // Structured metadata per signal (proximity window, hash values, etc.)
  signalDetails         Json?

  status                DuplicateFlagStatus @default(QUARANTINED)
  detectedAt            DateTime            @default(now())
  detectedBy            String              // "system" or userId

  // Override path — overrideJustification is required (enforced at API layer and audit trail)
  overriddenBy          String?
  overriddenAt          DateTime?
  overrideJustification String?

  // False-positive resolution
  resolvedBy            String?
  resolvedAt            DateTime?
  resolutionNotes       String?

  invoice               Invoice             @relation("DuplicateSuspect",  fields: [invoiceId],          references: [id])
  duplicateOf           Invoice?            @relation("DuplicateOriginal", fields: [duplicateOfInvoiceId], references: [id])

  @@index([orgId, status])
  @@index([invoiceId])
  @@index([duplicateOfInvoiceId])
  @@map("invoice_duplicate_flags")
}


// Approver assignment and decision record for an invoice.
// This is the source of truth for approver state; Invoice holds only a
// convenience back-relation (Invoice.approvals).
model InvoiceApproval {
  id          String                @id @default(cuid())
  invoiceId   String
  orgId       String
  assignedTo  String                // userId
  assignedBy  String                // userId or "system"
  assignedAt  DateTime              @default(now())
  role        OrgRole               // role at time of assignment
  status      InvoiceApprovalStatus @default(PENDING)
  decidedAt   DateTime?
  decision    String?               // APPROVED | REJECTED
  notes       String?
  delegatedTo String?               // userId if status = DELEGATED
  // Set when a pending reminder email was last sent
  lastReminderAt DateTime?

  invoice     Invoice               @relation(fields: [invoiceId], references: [id])
  org         Organisation          @relation(fields: [orgId], references: [id])
  assignee    User                  @relation("InvoiceAssignee", fields: [assignedTo], references: [id])

  @@index([invoiceId])
  @@index([assignedTo, status])
  @@index([orgId, status])
  @@map("invoice_approvals")
}

// Per-user notification preferences for invoice routing.
// emailOnInvoiceRouted defaults to true (Resend email sent on assignment).
// reminderAfterDays controls the fallback reminder cadence for pending invoices.
model NotificationPreference {
  id                   String   @id @default(cuid())
  userId               String   @unique
  orgId                String

  emailOnInvoiceRouted Boolean  @default(true)
  notifyOnApproval     Boolean  @default(true)
  reminderEnabled      Boolean  @default(true)
  reminderAfterDays    Int      @default(3)

  updatedAt            DateTime @updatedAt

  user                 User         @relation(fields: [userId], references: [id])
  org                  Organisation @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@map("notification_preferences")
}

// Parent record for a consolidated invoice authorization (batch approval + payment).
// Each member invoice retains its own record and full audit trail.
// totalAmount = simple sum of all member invoice amounts (no credit netting in v1).
model MergedAuthorization {
  id            String           @id @default(cuid())
  orgId         String
  reference     String           // human-readable batch reference
  name          String?
  totalAmount   Decimal          @db.Decimal(18, 4)
  currency      String
  status        MergedAuthStatus @default(DRAFT)
  createdBy     String
  approvedBy    String?
  approvedAt    DateTime?
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  org           Organisation     @relation(fields: [orgId], references: [id])
  items         MergedAuthItem[]

  @@unique([orgId, reference])
  @@index([orgId, status])
  @@map("merged_authorizations")
}

// Junction between a MergedAuthorization and its member invoices.
model MergedAuthItem {
  id             String              @id @default(cuid())
  mergedAuthId   String
  invoiceId      String              @unique // each invoice belongs to at most one merge
  amount         Decimal             @db.Decimal(18, 4)
  notes          String?

  mergedAuth     MergedAuthorization @relation(fields: [mergedAuthId], references: [id])
  invoice        Invoice             @relation(fields: [invoiceId], references: [id])

  @@index([mergedAuthId])
  @@map("merged_auth_items")
}

// Monthly spend snapshot per vendor/org pair for fast history queries.
// Computed periodically (nightly or on-demand); do not use as a billing ledger.
model VendorSpendSnapshot {
  id           String   @id @default(cuid())
  entityId     String
  orgId        String
  period       String   // "YYYY-MM"
  invoiceCount Int
  totalAmount  Decimal  @db.Decimal(18, 4)
  avgAmount    Decimal  @db.Decimal(18, 4)
  minAmount    Decimal  @db.Decimal(18, 4)
  maxAmount    Decimal  @db.Decimal(18, 4)
  currency     String
  computedAt   DateTime @default(now())

  entity       Entity   @relation(fields: [entityId], references: [id])

  @@unique([entityId, orgId, period, currency])
  @@index([entityId, orgId, period])
  @@map("vendor_spend_snapshots")
}

// ============================================================
// Unified Workflow Engine — Phase 3A
// ============================================================

enum WorkflowTargetType {
  ENTITY
  INVOICE
  PURCHASE_ORDER
}

enum WorkflowInstanceStatus {
  NOT_STARTED
  IN_PROGRESS
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

enum StepType {
  APPROVAL
  AUTO_RULE
  CONDITION_BRANCH
  NOTIFICATION
  WAIT_FOR
  SUB_WORKFLOW
}

enum StepExecutionMode {
  SYNC
  ASYNC
  PARALLEL
}

enum StepInstanceStatus {
  PENDING
  IN_PROGRESS
  WAITING
  COMPLETED
  SKIPPED
  FAILED
}

enum StepResult {
  PASS
  FAIL
}

enum OnMissingContext {
  WAIT
  SKIP
  FAIL
}

model WorkflowTemplate {
  id               String             @id @default(cuid())
  name             String
  description      String?
  targetObjectType WorkflowTargetType
  isActive         Boolean            @default(false)
  isValid          Boolean            @default(false)
  version          Int                @default(1)
  createdBy        String
  orgId            String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  steps            WorkflowStepDefinition[]
  selectionRules   TemplateSelectionRule[]
  instances        WorkflowInstance[]

  @@map("workflow_templates")
}

model WorkflowStepDefinition {
  id               String            @id @default(cuid())
  templateId       String
  name             String
  description      String?
  stepType         StepType
  executionMode    StepExecutionMode @default(SYNC)
  parallelGroupId  String?
  config           Json
  nextSteps        Json
  dependencies     Json              @default("[]")
  onMissingContext OnMissingContext  @default(FAIL)
  order            Int               @default(0)

  template         WorkflowTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  instances        WorkflowStepInstance[]

  @@map("workflow_step_definitions")
}

model WorkflowInstance {
  id                   String                 @id @default(cuid())
  templateId           String
  templateVersion      Int
  orgId                String
  targetObjectType     WorkflowTargetType
  targetObjectId       String
  status               WorkflowInstanceStatus @default(NOT_STARTED)
  parentInstanceId     String?
  parentStepInstanceId String?
  context              Json                   @default("{}")
  startedAt            DateTime?
  completedAt          DateTime?
  cancelledAt          DateTime?
  cancelledBy          String?
  createdAt            DateTime               @default(now())

  template             WorkflowTemplate       @relation(fields: [templateId], references: [id])
  stepInstances        WorkflowStepInstance[]

  @@index([targetObjectType, targetObjectId])
  @@index([status])
  @@map("workflow_instances")
}

model WorkflowStepInstance {
  id                 String              @id @default(cuid())
  workflowInstanceId String
  stepDefinitionId   String
  status             StepInstanceStatus  @default(PENDING)
  result             StepResult?
  assignedTo         String?
  startedAt          DateTime?
  completedAt        DateTime?
  completedBy        String?
  notes              String?
  metadata           Json                @default("{}")
  createdAt          DateTime            @default(now())

  workflowInstance   WorkflowInstance    @relation(fields: [workflowInstanceId], references: [id], onDelete: Cascade)
  stepDefinition     WorkflowStepDefinition @relation(fields: [stepDefinitionId], references: [id])
  dependencies       StepDependency[]

  @@map("workflow_step_instances")
}

model TemplateSelectionRule {
  id               String             @id @default(cuid())
  templateId       String
  orgId            String
  priority         Int
  triggerEvent     String
  targetObjectType WorkflowTargetType
  conditions       Json               @default("[]")
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now())

  template         WorkflowTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([targetObjectType, triggerEvent, priority])
  @@map("template_selection_rules")
}
